MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=swro
MYSQL_PASS=your_swro_password_here
JWT_SECRET=change_this_to_a_long_random_string

# Email (invite/reset emails) — Microsoft Graph API (no SMTP needed)
GRAPH_TENANT_ID=your_azure_tenant_id
GRAPH_CLIENT_ID=your_azure_client_id
GRAPH_CLIENT_SECRET=your_azure_client_secret
SMTP_FROM=no-reply@pxpsolutions.com
ALERT_EMAIL=your@email.com

# Full URL where the portal is hosted (used in invite links)
PORTAL_URL=http://localhost:5173

# UPS Tracking API (OAuth client credentials from developer.ups.com)
UPS_CLIENT_ID=your_ups_client_id
UPS_CLIENT_SECRET=your_ups_client_secret
UPS_ENV=production
