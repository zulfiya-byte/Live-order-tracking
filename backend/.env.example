MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=swro
MYSQL_PASS=your_swro_password_here
JWT_SECRET=change_this_to_a_long_random_string

# Email (invite emails) — use any SMTP provider
# Gmail: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
# Outlook: SMTP_HOST=smtp.office365.com, SMTP_PORT=587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password_here
SMTP_FROM=your@email.com

# Full URL where the portal is hosted (used in invite links)
PORTAL_URL=http://localhost:5173
